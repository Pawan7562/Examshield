{
  "name": "examshield",
  "version": "1.0.0",
  "description": "Professional Exam Management System with AI-Powered Question Generation",
  "main": "api/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && npm install && npm run build",
    "start": "node api/index.js",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "supabase": "^1.88.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "exam",
    "education",
    "ai",
    "proctoring",
    "react",
    "nodejs",
    "vercel"
  ],
  "author": "ExamShield Team",
  "license": "MIT"
}
